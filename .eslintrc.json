{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["google", "plugin:prettier/recommended"],
  "plugins": ["prettier"],
  "rules": {
    "prettier/prettier": [
      "error",
      {
        "singleQuote": true,
        "printWidth": 80,
        "tabWidth": 2,
        "semi": true,
        "trailingComma": "all",
        "arrowParens": "always",
        "endOfLine": "lf"
      }
    ]
  }
}
