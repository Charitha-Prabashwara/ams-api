# Server
APPLICATION_PORT=8080
NODE_ENV=production

# MongoDB
DB_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DB_MONGODB_DATABASE=AMS

# bcrypt
SLAT_ROUNDS=10

# JWT Secrets — use long, random strings in production
ACCESS_TOKEN_SECRET=replace_with_a_strong_random_secret
REFRESH_TOKEN_SECRET=replace_with_another_strong_random_secret

# JWT / Cookie TTLs
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=30d
REFRESH_TOKEN_COOKIE_TTL=3600

# CORS
ALLOWED_ORIGINS=["https://your-frontend.com"]
ALLOWED_METHODS=["GET","HEAD","PUT","PATCH","POST","DELETE"]
ALLOWED_HEADERS=["Origin","X-Requested-With","Content-Type","Accept","Authorization","X-Token"]
