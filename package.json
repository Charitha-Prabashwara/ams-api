{
  "name": "ams-api",
  "version": "1.0.0",
  "description": "This is a Backend service for AMS",
  "keywords": [
    "academic",
    "management",
    "university",
    "school",
    "gov",
    "education",
    "backend",
    "nodejs",
    "express",
    "mongodb",
    "jwt",
    "rbac",
    "res",
    "api"
  ],
  "main": "Server.js",
  "scripts": {
    "build": "node build.js",
    "pm2start": "pm2 start ecosystem.config.js --env production",
    "pm2dev": "pm2 start ecosystem.config.js --env development",
    "dev": "nodemon src/server.js",
    "dev:watch": "node --watch src/server.js",
    "test": "jest",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "assets": [
    "src/lang/**/*",
    "src/docs/**/*"
  ],
  "targets": [
    "node18-win-x64",
    "node18-linux-x64",
    "node18-macos-x64"
  ],
  "author": "Charitha Prabashwara",
  "license": "GPL-3.0",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "compression": "^1.8.1",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "ioredis": "^5.7.0",
    "joi": "^18.0.1",
    "joi-objectid": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.0.5",
    "mongodb-memory-server": "^10.2.3",
    "pm2": "^6.0.14",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4"
  }
}
